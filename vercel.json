{
  "version": 2,
  "rewrites": [{"source": "/static/(.*)", "destination": "/"}],
  "builds": [
    {
      "src": "src/app.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["static/**", "templates/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/src/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "src/app.py"
    }
  ]
}