{
  "version": 2,
  "rewrites": [{"source": "/static/(.*)", "destination": "/"}],
  "builds": [
    {
      "src": "src/app.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["static/**", "templates/**"]
      }
    }
  ],
  "env": {
      "FLASK_ENV": "production"
  },
  "routes": [
    {
        "src": "/static/(.*)",
        "dest": "../static/$1"
    },
    {
        "src": "/templates/(.*)",
        "dest": "../templates/$1"
    }
  ]
}