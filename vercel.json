{
  "version": 2,
  "builds": [
    {
      "src": "src/app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "^/static/(.*)$",
      "dest": "../src/static/$1"
    },
    {
      "src": "/src/templates/(.*)",
      "dest": "../src/templates/$1"
    },
    {
      "src": "/database/(.*)",
      "dest": "../src/database/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/src/app.py"
    }
  ]
}