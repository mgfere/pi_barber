{
  "version": 2,
  "rewrites": [{"source": "/static/(.*)", "destination": "/"}],
  
  "env": {
      "FLASK_ENV": "production"
  },
  "routes": [
      {
          "src": "/static/(.*)",
          "dest": "../static/$1"
      },
      {
          "src": "/templates/(.*)",
          "dest": "../templates/$1"
      },
      {
          "src": "/(.*)",
          "dest": "../src/$1"
      }
  ]
}